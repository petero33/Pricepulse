# ─── Application ─────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
FRONTEND_URL=http://localhost:3000

# ─── Database (PostgreSQL via docker-compose) ─────────────────────────────────
DATABASE_URL="postgresql://pricepulse:pricepulse_secret@localhost:5432/pricepulse?schema=public"

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ─── Elasticsearch ───────────────────────────────────────────────────────────
ELASTICSEARCH_NODE=http://localhost:9200

# ─── JWT Authentication ───────────────────────────────────────────────────────
JWT_SECRET=your-super-secret-jwt-key-change-in-production-min-32-chars
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-in-production-min-32-chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# ─── Google OAuth ────────────────────────────────────────────────────────────
# Get from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# ─── Africa's Talking (SMS / OTP) ────────────────────────────────────────────
# Get from: https://account.africastalking.com/
# Use "sandbox" username for development
AT_API_KEY=your-africastalking-api-key
AT_USERNAME=sandbox
AT_SENDER_ID=PricePulse

# ─── Firebase (Storage + FCM Push Notifications) ─────────────────────────────
# Get from: Firebase Console → Project Settings → Service Accounts → Generate key
FIREBASE_PROJECT_ID=your-firebase-project-id
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
# Paste the private key exactly as in the JSON (with \n newlines)
FIREBASE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
FIREBASE_STORAGE_BUCKET=your-firebase-project.appspot.com

# FCM Server Key (for push notifications — from Firebase Console → Cloud Messaging)
FCM_SERVER_KEY=your-fcm-server-key

# ─── Mapbox (Free tier — 50k map loads/month) ────────────────────────────────
# Get from: https://account.mapbox.com/access-tokens/
# IMPORTANT: Scope to specific URLs in Mapbox dashboard to prevent abuse
MAPBOX_ACCESS_TOKEN=pk.your-mapbox-public-token-here

# ─── Rate Limiting ───────────────────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=100

# ─── OCR (Tesseract — Phase 2) ───────────────────────────────────────────────
# Leave empty in Phase 1
GOOGLE_CLOUD_VISION_KEY=

# ─── Bonsai Elasticsearch (Free 125MB — production alternative) ──────────────
# Sign up at: https://bonsai.io (free tier: 125MB, 3 shards)
# Uncomment for production: ELASTICSEARCH_NODE=https://user:pass@host.bonsaisearch.net:443
